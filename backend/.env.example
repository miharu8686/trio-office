# trio-office backend configuration
# Copy this file to backend/.env before starting the backend.

# Disable AI-powered summaries (agent names, task blurbs). The default backend
# ("claude-cli") silently invokes the `claude` CLI, which can incur API billing
# when ANTHROPIC_API_KEY is set in the environment. Keep disabled unless you
# have explicitly decided otherwise.
SUMMARY_BACKEND=disabled
SUMMARY_ENABLED=false
